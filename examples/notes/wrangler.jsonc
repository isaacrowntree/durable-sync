{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "durable-sync-notes",
  "main": "worker.js",
  // Pinned to match the workerd that ships with the installed wrangler; bump
  // both together.
  "compatibility_date": "2026-06-24",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [{ "name": "JOURNAL", "class_name": "Journal" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["Journal"] }]
}
