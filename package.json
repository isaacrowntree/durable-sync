{
  "name": "durable-sync",
  "version": "0.2.0",
  "description": "Offline-first sync for Cloudflare Durable Objects: an append-only op log on the server, an outbox on the client.",
  "license": "MIT",
  "author": "Isaac Rowntree",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaacrowntree/durable-sync.git"
  },
  "homepage": "https://isaacrowntree.com/durable-sync/",
  "bugs": {
    "url": "https://github.com/isaacrowntree/durable-sync/issues"
  },
  "keywords": [
    "cloudflare",
    "durable-objects",
    "workers",
    "offline-first",
    "local-first",
    "sync",
    "oplog",
    "event-sourcing",
    "indexeddb",
    "pwa"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "exports": {
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
