{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "node",
      "@cloudflare/workers-types"
    ]
  },
  "include": [
    "src/**/*.ts"
  ]
}
